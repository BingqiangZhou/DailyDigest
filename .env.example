# 环境变量模板 - 复制为 .env 并填入实际值

# OpenAI 兼容 API Key (必需 - GitHub Actions 模式)
# 支持 NVIDIA NIM、DeepSeek、Ollama、vLLM 等所有 OpenAI 兼容格式
API_KEY=sk-xxxxx

# API 配置 (可选，使用默认值即可)
# BASE_URL=https://integrate.api.nvidia.com/v1
# MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# YouTube 字幕提取 (可选，不配置则跳过字幕获取)
# SUPADATA_API_KEY=sd-xxxxx

# 报告语言: zh / en
REPORT_LANGUAGE=zh

# 每个RSS源最大文章数
MAX_ARTICLES_PER_FEED=10

# 抓取时间范围（小时）
HOURS_BACK=48

# 请求超时（秒）
TIMEOUT_SECONDS=15
